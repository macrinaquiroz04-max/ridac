<?xml version="1.0" standalone='no'?><!--*-nxml-*-->
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">

<!-- 
    Servicio Avahi/mDNS para Sistema OCR
    Desarrollador: Eduardo Lozada Quiroz, ISC
    Cliente: Unidad de Análisis y Contexto (UAyC) - FGJCDMX
    Año: 2025
    
    Este servicio anuncia el sistema en la red local usando mDNS
    Las PCs pueden acceder sin configurar DNS usando:
    - http://sistema-ocr.local
    - http://fgj-ocr.local
-->

<service-group>
    <name replace-wildcards="yes">Sistema OCR - FGJCDMX</name>
    
    <!-- Servicio HTTP -->
    <service>
        <type>_http._tcp</type>
        <port>80</port>
        <txt-record>path=/</txt-record>
        <txt-record>description=Sistema OCR con Análisis Jurídico - FGJCDMX</txt-record>
        <txt-record>version=2025</txt-record>
    </service>
    
    <!-- Servicio HTTPS (preparado para futuro) -->
    <service>
        <type>_https._tcp</type>
        <port>443</port>
        <txt-record>path=/</txt-record>
    </service>
</service-group>
