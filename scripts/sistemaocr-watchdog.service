[Unit]
Description=Watchdog para Sistema OCR FGJCDMX - Auto-reinicia servicios en fallos
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=eduardo
WorkingDirectory=/home/eduardo/Descargas/sistemaocr
ExecStart=/home/eduardo/Descargas/sistemaocr/scripts/watchdog_restart.sh
Restart=always
RestartSec=10
StandardOutput=append:/home/eduardo/Descargas/sistemaocr/logs/watchdog.out
StandardError=append:/home/eduardo/Descargas/sistemaocr/logs/watchdog.err
SyslogIdentifier=sistemaocr-watchdog

[Install]
WantedBy=multi-user.target
