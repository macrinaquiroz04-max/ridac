# =============================================
# BACKEND — Variables de entorno para producción
# Cloudflare + Supabase + Render + Upstash Redis
# =============================================

# --- Supabase PostgreSQL (Supabase > Project > Settings > Database) ---
# Formato: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[TU_REF]:[TU_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# O bien variables separadas (si prefieres):
# DB_HOST=aws-0-us-east-1.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres.[TU_REF]
# DB_PASSWORD=TU_PASSWORD

# --- Redis (Upstash: https://console.upstash.com) ---
# En Render puedes también usar Render Redis (plan free)
REDIS_URL=rediss://default:[TU_TOKEN]@[TU_HOST].upstash.io:6379

# --- JWT ---
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CAMBIA_ESTO_POR_UN_SECRET_REAL_DE_64_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CORS (dominio frontend en Cloudflare Pages) ---
# Pon el dominio real de tu app en Cloudflare Pages
FRONTEND_URL=https://tu-app.pages.dev

# --- Rutas (Render usa sistema de archivos efímero, usa /tmp) ---
UPLOAD_PATH=/tmp/ridac/documentos
EXPORT_PATH=/tmp/ridac/exportaciones
TEMP_PATH=/tmp/ridac/temp
LOG_PATH=/tmp/ridac/logs

# --- OCR ---
OCR_ENABLE_TESSERACT=true
OCR_MAX_WORKERS=2

# --- Servidor ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
